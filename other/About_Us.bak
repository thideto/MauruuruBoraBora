      <TD width="800" valign="middle" bgcolor="#ffffff" height="80"><B><IMG src="../img/Blank.gif" width="9" height="9" border="0">　<FONT color="#999999">MauruuruBoraBora &gt; About Us</FONT></B><BR>
      <IMG src="../img/Blank.gif" width="5" height="60" border="0"><IMG src="button111.gif" width="398" height="58" border="0" alt=""><IMG src="../img/Blank.gif" width="9" height="10" border="0"></TD>
